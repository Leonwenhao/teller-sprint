# Teller configuration
# Copy to .env and fill in actual values.

# OpenRouter API key for the default MiniMax M2.5 model.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# SEC EDGAR requires identifying yourself in the user-agent header.
# Format: "ApplicationName ContactEmail"
# Default is set in code; override here if deploying under a different identity.
# TELLER_SEC_USER_AGENT="Teller (Dolores Research) leon@dolores.research"
